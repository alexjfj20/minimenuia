# ===========================================
# VARIABLES DE ENTORNO PARA MINIMENU
# ===========================================
# Copia este archivo a .env.local y reemplaza los valores
# NUNCA hagas commit de .env.local

# ===========================================
# SUPABASE (Base de datos y autenticación)
# ===========================================

# URL de tu proyecto Supabase
# Ejemplo: https://abcdefghijk.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clave ANON (pública) de Supabase
# La encuentras en: Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave SERVICE_ROLE (SECRETA) de Supabase
# ⚠️ NUNCA la expongas en el frontend
# La encuentras en: Settings → API → Project API keys → service_role
# Solo se usa en API Routes (backend)
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# NOTAS IMPORTANTES
# ===========================================
#
# Para Vercel:
# 1. Ve a tu proyecto en Vercel Dashboard
# 2. Settings → Environment Variables
# 3. Agrega las 3 variables para Production, Preview y Development
# 4. Haz redeploy después de agregar las variables
#
# Para desarrollo local:
# 1. Copia este archivo a .env.local
# 2. Reemplaza los valores con tus credenciales
# 3. Reinicia el servidor de desarrollo (npm run dev)
